{%- if itch  -%}
itch-page := 'null'
{% endif %}

{%- if web -%}
web-target := 'web'
{%- endif %}
win-target := 'x86_64-pc-windows-gnu'
linux-target := 'x86_64-unknown-linux-gnu'

{%- if itch %}
{% if web %}
web-channel := 'web'
{%- endif %}
win-channel := 'windows'
linux-channel := 'linux'
{%- endif %}

bin-name := shell("cargo metadata --format-version 1 --no-deps | jq -r '[.packages[0].targets[] | select(.kind[]) | select (.kind[] | select(. == \"bin\")) | .name][0]'")
target-dir := shell("cargo metadata --format-version 1 --no-deps | jq -r '.target_directory'")
{%- if itch %}
crate-version := shell("cargo metadata --format-version 1 --no-deps | jq -r '.packages[0].version'")
{%- endif %}

# run the project
[arg("args", help="args to pass to the bevy cli")]
run *args:
{%- raw %}
    bevy run {{ args }}
{%- endraw -%}
{% if itch %}

# build and publish the project to itch.io
{%- if web %}
[arg("target", help="a rustc target triple, `web`, or `all` (web, linux, windows)")]
{%- else %}
[arg("target", help="a rustc target triple, or `all` (linux and windows)")]
{%- endif %}
[arg("args", help="args to pass to the bevy cli")]
[arg("publish", long="dry-run", value="false", help="don't publish anything")]
[arg("validate", long="no-validate", value="false", help="don't validate the git index status & itch.io page")]
[arg("build", long="no-build", value="false", help="publish whatever is already in target/out")]
[arg("channel", long="channel", help="the butler channel to publish the build to")]
[confirm("are you sure you want to publish a build?")]
[script]
publish target="all" channel="" build="true" validate="true" publish="true" *args: (validate validate)
    {%- raw %}
    if [ '{{ target }}' == 'all' ]; then
        if {{ build }}; then
            just build all {{ args }}
        fi

        dry=''
        if ! {{ publish }};  then
            dry='--dry-run'
        fi

    {%- endraw %}
{% if web %}
    {%- raw %}
        just --yes publish '{{ web-target }}' --channel '{{ web-channel }}' --no-build --no-validate $dry {{ args }}
    {%- endraw %}
{%- endif %}
    {%- raw %}
        just --yes publish '{{ win-target }}' --channel '{{ win-channel }}' --no-build --no-validate $dry {{ args }}
        just --yes publish '{{ linux-target }}' --channel '{{ linux-channel }}' --no-build --no-validate $dry {{ args }}
        exit 0
    fi

    if {{ build }}; then
        just build '{{ target }}' {{ args }}
    fi

    echo "{{ BOLD }}publishing 'target/out/{{ target }}' to {{ itch-page }}:{{ channel }}{{ NORMAL }}"

    if {{ publish }}; then
        butler push 'target/out/{{ target }}' '{{ itch-page }}:{{ channel }}' --userversion '{{ crate-version }}'
    fi
    {%- endraw -%}
{%- endif %}

# build the project for release
{%- if web %}
[arg("target", help="a rustc target triple, `web`, or `all` (web, linux, windows)")]
{%- else %}
[arg("target", help="a rustc target triple, or `all` (linux and windows)")]
{%- endif %}
[arg("args", help="args to pass to the bevy cli")]
[script]
build target="all" *args:
    {%- raw %}
    if [ '{{ target }}' == 'all' ]; then
    {%- endraw %}
{%- if web %}
    {%- raw %}
        just build '{{ web-target }}' {{ args }}
    {%- endraw %}
{%- endif %}
    {%- raw %}
        just build '{{ win-target }}' {{ args }}
        just build '{{ linux-target }}' {{ args }}
    {%- endraw %}
{%- if web %}
    {%- raw %}
    elif [ '{{ target }}' == "web" ]; then
        echo "{{ BOLD }}building target '{{ target }}'{{ NORMAL }}"

        rm -rf 'target/out/{{ web-target }}'
        mkdir -p 'target/out/{{ web-target }}'

        bevy build {{ args }} --release web --bundle
        cp -r '{{ target-dir }}/bevy_web/web-release/{{ bin-name }}/'* 'target/out/{{ web-target }}'
    {%- endraw %}
{%- endif %}
    {%- raw %}
    else
        echo "{{ BOLD }}building target '{{ target }}'{{ NORMAL }}"

        rm -rf 'target/out/{{ target }}'
        mkdir -p 'target/out/{{ target }}'

        ext='{{ if target =~ ".*windows.*" { ".exe" } else { "" } }}'
        bevy build {{ args }} --release --target '{{ target }}'
        mv '{{ target-dir }}/{{ target }}/release/{{ bin-name }}'"$ext" 'target/out/{{ target }}'
        cp -r 'assets' 'target/out/{{ target }}'
    fi
    {%- endraw %}

{% if itch %}
    {%- raw -%}
# validates that the git index is clean and the itch.io page is valid
[no-exit-message]
[private]
validate validate='true': (validate-git validate) (validate-itch validate)

# validates that the git working directory has no uncommited changes
[no-exit-message]
[private]
[script]
validate-git validate='true':
    if {{ validate }} && [ -n "$(git status --porcelain)" ]; then
        echo '{{ style("error") }}error{{ NORMAL }}{{ BOLD }}: git working directory must be clean!{{ NORMAL }}'
        exit 1
    fi

# validates that the itch.io page is valid
[no-exit-message]
[private]
[script]
validate-itch validate='true':
    if {{ validate }} && ! butler status '{{ itch-page }}' > /dev/null; then
        echo "{{ style('error') }}error{{ NORMAL }}{{ BOLD }}: itch.io page '{{ itch-page }}' is invalid or no access!"
        exit 1
    fi
    {%- endraw -%}
{%- endif -%}
