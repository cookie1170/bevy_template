// support configuring bevy lints within code
#![cfg_attr(bevy_lint, feature(register_tool), register_tool(bevy))]
// disable console on windows for non-dev builds
#![cfg_attr(not(feature = "dev"), windows_subsystem = "windows")]

pub(crate) mod prelude;

use crate::prelude::*;
use bevy::log::{self, Level, LogPlugin};

fn main() -> AppExit {
    let mut app = App::new();

    // don't panic when systems return an error!
    app.set_error_handler(bevy::ecs::error::warn);

    let mut default_plugins = DefaultPlugins.build();

    default_plugins = default_plugins.set(LogPlugin {
        #[cfg(feature = "dev")]
        // set the default log level to be `debug` for this crate
        filter: format!("{}=debug,{}", env!("CARGO_PKG_NAME"), log::DEFAULT_FILTER),
        #[cfg(feature = "dev")]
        level: Level::INFO,
        ..default()
    });
    {%- if nearest_filter %}

    default_plugins = default_plugins.set(ImagePlugin::default_nearest());
    {%- endif %}
    {%- if web %}

    default_plugins = default_plugins.set(AssetPlugin {
        // wasm builds will check for meta files (that don't exist) if this isn't set
        // this causes errors and even panics on web build on itch
        meta_check: bevy::asset::AssetMetaCheck::Never,
        ..default()
    });

    default_plugins = default_plugins.set(WindowPlugin {
        primary_window: Window {
            fit_canvas_to_parent: true,
            ..default()
        }
        .into(),
        ..default()
    });
    {%- endif %}

    app.add_plugins(default_plugins);

    app.run()
}
